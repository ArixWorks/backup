// Bot Subio - Telegram Auction & Flash Sale Platform
// Core data model. Money is stored as BigInt in Toman (no decimal places).
// This schema is portable: it runs unchanged against self-hosted PostgreSQL 16.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection for the app runtime (PgBouncer / Neon pooler).
  url       = env("POSTGRES_PRISMA_URL")
  // Direct connection for migrations / db push.
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  BANNED
}

enum AuthTokenType {
  EMAIL_VERIFY
  PASSWORD_RESET
}

enum WalletTxType {
  DEPOSIT
  WITHDRAWAL
  FREEZE
  UNFREEZE
  PURCHASE
  REFUND
  BID_LOCK
  BID_RELEASE
  ADMIN_ADJUSTMENT
  CASHBACK
  REFERRAL_BONUS
  // Moving funds between two of a user's own currency wallets.
  CONVERSION
}

// Chart of accounts for the double-entry ledger. USER_* accounts are per-user
// and per-currency; SYS_* accounts are global per-currency system accounts.
// Every posted entry's legs must sum to zero within a single currency.
enum LedgerAccountKind {
  USER_AVAILABLE // a user's spendable balance
  USER_FROZEN // a user's escrowed/locked balance (bids, reservations)
  SYS_CASH // real money received via deposits (card-to-card)
  SYS_REVENUE // platform revenue from purchases / refunds
  SYS_WITHDRAWALS_PAYABLE // amounts owed to users for approved withdrawals
  SYS_PROMO_EXPENSE // cashback, referral bonuses and other promotions
  SYS_ADJUSTMENTS // manual admin credits/debits
  SYS_FX_CLEARING // counterparty for currency conversions
  SYS_OPENING_BALANCE // counterparty for the go-live opening-balance backfill
}

enum CouponType {
  PERCENT
  FIXED
}

enum SaleMode {
  FIXED_PRICE
  AUCTION
}

enum DeliveryType {
  MANUAL
  AUTOMATIC
}

enum AuctionStatus {
  SCHEDULED
  ACTIVE
  ENDED
  FINALIZED
  CANCELLED
}

enum OrderType {
  FIXED_PURCHASE
  BUY_NOW
  AUCTION_WIN
}

enum OrderStatus {
  PENDING
  PAID
  DELIVERED
  REFUNDED
  CANCELLED
}

enum InventoryStatus {
  AVAILABLE
  RESERVED
  DELIVERED
}

enum DeliveryStatus {
  PENDING
  DELIVERED
  FAILED
}

enum DepositStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum DepositMethod {
  CARD
  TON
  USDT
  STARS
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum RefundStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

// User-facing support ticket lifecycle.
enum SupportStatus {
  OPEN // newly created / awaiting first staff reply
  ANSWERED // staff has replied, awaiting user
  PENDING // user replied, awaiting staff
  CLOSED // resolved / archived
}

enum SupportCategory {
  GENERAL
  PAYMENT
  ORDER
  REFUND
  TECHNICAL
}

// ---------------------------------------------------------------------------
// Users & Wallet
// ---------------------------------------------------------------------------

model User {
  id          String     @id @default(cuid())
  email       String?    @unique
  // Argon2id password hash for email/password login (null = Telegram-only account).
  // Legacy scrypt hashes are still accepted and transparently rehashed on next login.
  passwordHash String?
  // True once the email address has been confirmed via a verification token.
  // A verified email is locked and can no longer be changed from the UI.
  emailVerified Boolean   @default(false)
  // Forces a password change on next login (used for the seeded admin account).
  mustChangePassword Boolean @default(false)
  // "telegram" | "password" — the method used for the most recent successful login.
  lastLoginMethod String?
  // Bumped to invalidate every existing signed session (logout from all devices).
  tokenVersion Int        @default(0)
  telegramId  String?    @unique
  // Telegram chat id used for push notifications (usually equals telegramId for private chats).
  telegramChatId String?
  telegramUsername String?
  photoUrl    String?
  languageCode String?
  // True once the user manually picks a language, so Telegram's language_code stops overriding it.
  localeManual Boolean   @default(false)
  isPremium   Boolean    @default(false)
  username    String?    @unique
  displayName String
  alias       String     @unique // public pseudonym shown in bid history
  role        UserRole   @default(USER)
  status      UserStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Referral program: each user has a shareable code; referredById points to
  // the inviter. referralRewarded flips true once the first-purchase bonus is paid.
  referralCode     String?  @unique
  referredById     String?
  referredBy       User?    @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals        User[]   @relation("UserReferrals")
  // referralRewarded flips true once the one-time first-purchase bonus is paid.
  referralRewarded Boolean  @default(false)
  // referralJoinRewarded flips true once the inviter's "joined" bonus (stage A:
  // friend started the bot and passed the forced-join gate) is paid. Separate
  // guard so the join reward and the first-purchase reward each pay exactly once.
  referralJoinRewarded Boolean @default(false)

  // Gamification & loyalty -------------------------------------------------
  // loyaltyPoints is the current spendable balance; lifetimePoints is the
  // monotonic total ever earned and is one of the two VIP-tier drivers.
  loyaltyPoints    Int       @default(0)
  lifetimePoints   Int       @default(0)
  // totalSpent is lifetime spend in IRT minor units, the other VIP driver.
  totalSpent       BigInt    @default(0)
  // vipTier holds the EARNED auto tier (STANDARD..DIAMOND), never VIP.
  vipTier          VipTier   @default(STANDARD)
  vipSince         DateTime?
  // Exclusive VIP membership, granted only by an admin. When vipManual is true
  // (and not past vipManualExpiresAt) the user's effective tier is VIP,
  // overriding their earned tier. Admin can toggle it on/off at any time.
  vipManual          Boolean   @default(false)
  vipManualExpiresAt DateTime?
  // Daily-login streak tracking for the "daily login" mission.
  lastLoginDay     String?   // "YYYY-MM-DD" of the last counted login
  loginStreak      Int       @default(0)
  profileCompleted Boolean   @default(false)
  // Set once the user finishes the first-run onboarding flow (join gate →
  // language → guided tutorial → success). Null means onboarding is pending.
  onboardedAt      DateTime?

  pointEntries PointLedger[]
  userBadges   UserBadge[]
  userMissions UserMission[]

  wallets     Wallet[]
  ledgerAccounts LedgerAccount[]
  conversions CurrencyConversion[]
  bids        Bid[]
  orders      Order[]
  watchlist   WatchlistEntry[]
  auditLogs   AuditLog[]
  deposits    DepositRequest[]
  withdrawals WithdrawalRequest[]
  refunds     RefundRequest[]
  tickets     SupportTicket[]
  reviews     Review[]
  redemptions CouponRedemption[]
  notifications Notification[]
  stockAlerts StockAlert[]
  categoryFollows CategoryFollow[]
  authTokens  AuthToken[]
  giveawayEntries  GiveawayEntry[]
  giveawayWins     GiveawayWinner[]

  @@index([status])
  @@index([referredById])
}

// Single-use tokens for email verification and password reset. Only the SHA-256
// hash of the token is stored, so a database leak cannot reveal usable links.
model AuthToken {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      AuthTokenType
  // SHA-256 hex of the raw token sent to the user.
  tokenHash String        @unique
  // For EMAIL_VERIFY: the pending email address awaiting confirmation.
  email     String?
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime      @default(now())

  @@index([userId, type])
  @@index([expiresAt])
}

model Wallet {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // ISO-ish currency code (e.g. "IRT", "USD", "USDT"). One wallet per user per currency.
  currency      String   @default("IRT")
  totalBalance  BigInt   @default(0)
  frozenBalance BigInt   @default(0)
  // Optimistic-locking guard against concurrent balance mutations.
  version       Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transactions WalletTransaction[]

  @@unique([userId, currency])
}

// Immutable ledger. Records are never updated or deleted.
model WalletTransaction {
  id          String       @id @default(cuid())
  walletId    String
  wallet      Wallet       @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type        WalletTxType
  // Denormalised currency of the wallet, copied for convenient querying.
  currency    String       @default("IRT")
  amount      BigInt // signed delta applied by this entry
  balanceAfter BigInt
  frozenAfter BigInt
  refType     String? // e.g. "auction", "order", "deposit"
  refId       String?
  note        String?
  createdAt   DateTime     @default(now())

  @@index([walletId, createdAt])
  @@index([refType, refId])
}

// ---------------------------------------------------------------------------
// Currencies, exchange rates & conversions (multi-currency support)
// ---------------------------------------------------------------------------

model Currency {
  code         String   @id // "IRT", "USD", "USDT"
  name         String
  symbol       String
  // Minor-unit precision used for display (IRT=0, USD=2, USDT=2).
  decimals     Int      @default(0)
  isBase       Boolean  @default(false) // exactly one base currency (IRT)
  isActive     Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Exchange rate history. rate is scaled by 1e8 and expresses how many units of
// quoteCode equal one unit of baseCode. Latest row per pair wins.
model ExchangeRate {
  id          String   @id @default(cuid())
  baseCode    String
  quoteCode   String
  rate        BigInt // scaled ×1e8
  updatedById String?
  createdAt   DateTime @default(now())

  @@index([baseCode, quoteCode, createdAt])
}

// Audit record of a user converting between two of their currency wallets.
model CurrencyConversion {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromCode   String
  toCode     String
  fromAmount BigInt
  toAmount   BigInt
  rateUsed   BigInt // scaled ×1e8
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
}

// ---------------------------------------------------------------------------
// Double-entry ledger (authoritative accounting record)
// ---------------------------------------------------------------------------

model LedgerAccount {
  id          String            @id @default(cuid())
  kind        LedgerAccountKind
  // Set for USER_* accounts; null for SYS_* accounts.
  ownerUserId String?
  owner       User?             @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  currency    String            @default("IRT")
  balance     BigInt            @default(0)
  // Optimistic-locking guard for concurrent leg postings.
  version     Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  legs LedgerLeg[]

  @@unique([kind, ownerUserId, currency])
  @@index([currency])
}

// A balanced accounting entry. Its legs always sum to zero within one currency.
model LedgerEntry {
  id          String       @id @default(cuid())
  publicId    String       @unique
  kind        WalletTxType
  currency    String       @default("IRT")
  refType     String?
  refId       String?
  memo        String?
  createdById String?
  // Correlates this entry with the legacy WalletTransaction record, if any.
  walletTxId  String?
  createdAt   DateTime     @default(now())

  legs LedgerLeg[]

  @@index([kind, createdAt])
  @@index([refType, refId])
  @@index([walletTxId])
}

// One side of a ledger entry. amount is signed; balanceAfter snapshots the
// account balance immediately after this leg was applied.
model LedgerLeg {
  id          String        @id @default(cuid())
  entryId     String
  entry       LedgerEntry   @relation(fields: [entryId], references: [id], onDelete: Cascade)
  accountId   String
  account     LedgerAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  amount      BigInt // signed; sum across an entry's legs == 0
  balanceAfter BigInt
  createdAt   DateTime      @default(now())

  @@index([accountId, createdAt])
  @@index([entryId])
}

// ---------------------------------------------------------------------------
// Products
// ---------------------------------------------------------------------------

model Product {
  id           String       @id @default(cuid())
  slug         String       @unique // unguessable secure random id
  title        String
  description  String?
  // Native multilingual copy generated by the AI Copilot. Shape:
  // { fa?: {title,shortDescription,description}, en?: {...}, ru?: {...}, hi?: {...} }
  // The scalar title/description above stay as the primary (fa) fallback.
  i18n         Json?
  category     String?
  tags         String[]     @default([])
  coverImage   String?
  gallery      String[]     @default([])
  // Extra labeled links shown on the product card (e.g. Activation Link, Warranty).
  // Array of { label, url }.
  links        Json?
  saleMode     SaleMode
  deliveryType DeliveryType @default(MANUAL)
  hidden       Boolean      @default(false)
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  fixedSale      FixedSale?
  auction        Auction?
  inventoryItems InventoryItem[]
  orders         Order[]
  reviews        Review[]
  stockAlerts    StockAlert[]
  giveaways      Giveaway[]

  @@index([saleMode, active, hidden])
}

// ---------------------------------------------------------------------------
// Reviews & ratings (one per user per product, gated by a delivered order)
// ---------------------------------------------------------------------------

model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int // 1..5
  comment   String?
  // Hidden by an admin (kept for audit, excluded from public aggregates).
  hidden    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@index([productId, hidden])
}

// ---------------------------------------------------------------------------
// Coupons / discount codes
// ---------------------------------------------------------------------------

model Coupon {
  id           String     @id @default(cuid())
  code         String     @unique // stored uppercase
  type         CouponType
  // For PERCENT: 1..100. For FIXED: discount amount in minor units (Toman).
  value        BigInt
  // Optional cap on the discount when type is PERCENT (minor units).
  maxDiscount  BigInt?
  // Minimum order total required to use the coupon (minor units).
  minOrder     BigInt     @default(0)
  // Max redemptions per user (null = unlimited).
  perUserLimit Int?
  // Max total redemptions across all users (null = unlimited).
  totalLimit   Int?
  usedCount    Int        @default(0)
  active       Boolean    @default(true)
  startsAt     DateTime?
  expiresAt    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  redemptions CouponRedemption[]

  @@index([active])
}

model CouponRedemption {
  id        String   @id @default(cuid())
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId   String   @unique
  amount    BigInt // discount applied (minor units)
  createdAt DateTime @default(now())

  @@index([couponId, userId])
}

// ---------------------------------------------------------------------------
// Key-value app settings (cashback %, referral rewards, feature toggles)
// ---------------------------------------------------------------------------

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// In-app notification center + back-in-stock / product watch alerts
// ---------------------------------------------------------------------------

enum NotificationType {
  GENERAL
  BACK_IN_STOCK
  NEW_PRODUCT
  ORDER_DELIVERED
  AUCTION_STARTED
  AUCTION_WON
  DEPOSIT_APPROVED
  WITHDRAW_APPROVED
  CASHBACK
  REFERRAL_BONUS
  // Smart / engagement notifications
  AUCTION_ENDING
  AUCTION_OUTBID
  AUCTION_LOST
  GIVEAWAY_STARTED
  GIVEAWAY_WON
  PRICE_DROP
  COUPON_ACTIVE
  COUPON_EXPIRING
  REFUND_RECEIVED
  VIP_EXPIRING
  VIP_UPGRADED
  LOW_BALANCE
  POINTS_EARNED
  BADGE_AWARDED
  MISSION_COMPLETE
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType @default(GENERAL)
  title     String
  body      String
  // Optional deep link target (e.g. /flash/<id>) and thumbnail.
  href      String?
  image     String?
  read      Boolean          @default(false)
  // Archived notifications are hidden from the default inbox view but retained.
  archived  Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, read])
  @@index([userId, archived])
  @@index([userId, createdAt])
}

// A user's request to be alerted when a specific product is back in stock.
// Doubles as the "product watchlist" (flash sales), parallel to WatchlistEntry
// which covers auctions. notified flips true once a restock alert is sent and
// resets when the product sells out again, enabling repeat alerts.
model StockAlert {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([productId, notified])
}

// A user's subscription to a product category. When a new (visible) product is
// added in that category, every follower receives a NEW_PRODUCT notification.
model CategoryFollow {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  String
  createdAt DateTime @default(now())

  @@unique([userId, category])
  @@index([category])
}

// ---------------------------------------------------------------------------
// Fixed-price (Flash Sale)
// ---------------------------------------------------------------------------

model FixedSale {
  id            String    @id @default(cuid())
  productId     String    @unique
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  price         BigInt
  stock         Int       @default(0)
  reservedStock Int       @default(0) // temporary reservations for in-flight checkouts
  purchaseLimit Int? // max units per user
  // Real number of units sold through the bot/app (incremented per purchase).
  soldCount     Int       @default(0)
  // Vanity baseline added to soldCount for public display (editable in admin).
  soldBaseline  Int       @default(0)
  // Bulk discount: when quantity >= bulkMinQty, apply bulkDiscountPercent off.
  bulkMinQty          Int?
  bulkDiscountPercent Int?
  startTime     DateTime?
  endTime       DateTime?
  version       Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ---------------------------------------------------------------------------
// Auctions
// ---------------------------------------------------------------------------

model Auction {
  id                String        @id @default(cuid())
  productId         String        @unique
  product           Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  startPrice        BigInt
  currentPrice      BigInt        @default(0)
  minimumIncrement  BigInt        @default(1000)
  reservePrice      BigInt?
  buyNowPrice       BigInt?
  startTime         DateTime
  endTime           DateTime
  antiSnipingEnabled Boolean      @default(true)
  antiSnipingSeconds Int          @default(120)
  autoExtend        Boolean       @default(true)
  quantity          Int           @default(1) // multi-winner support
  status            AuctionStatus @default(SCHEDULED)
  // Optimistic-locking guard for bid races.
  version           Int           @default(0)
  // Idempotency flag: set true once the "ending soon" alert has been sent.
  endingSoonNotified Boolean      @default(false)
  finalizedAt       DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  bids      Bid[]
  orders    Order[]
  watchers  WatchlistEntry[]

  @@index([status, endTime])
}

model Bid {
  id        String   @id @default(cuid())
  auctionId String
  auction   Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    BigInt
  isAuto    Boolean  @default(false) // generated by auto-bid engine
  maxAmount BigInt? // ceiling for auto-bid
  createdAt DateTime @default(now())

  @@index([auctionId, amount])
  @@index([auctionId, userId])
}

model WatchlistEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  auctionId String
  auction   Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([userId, auctionId])
}

// ---------------------------------------------------------------------------
// Orders & Delivery
// ---------------------------------------------------------------------------

model Order {
  id          String      @id @default(cuid())
  publicId    String      @unique // unguessable reference
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId   String
  product     Product     @relation(fields: [productId], references: [id])
  auctionId   String?
  auction     Auction?    @relation(fields: [auctionId], references: [id])
  type        OrderType
  status      OrderStatus @default(PENDING)
  amount      BigInt
  quantity    Int         @default(1)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  delivery Delivery?

  @@index([userId, createdAt])
}

model Delivery {
  id              String         @id @default(cuid())
  orderId         String         @unique
  order           Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  method          DeliveryType
  status          DeliveryStatus @default(PENDING)
  inventoryItemId String?        @unique
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  payload         Json? // delivered credentials / manual message
  error           String?
  deliveredAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

// Inventory pool for automatic delivery. Each item is single-use.
model InventoryItem {
  id          String          @id @default(cuid())
  productId   String
  product     Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  username    String?
  password    String?
  licenseKey  String?
  note        String?
  status      InventoryStatus @default(AVAILABLE)
  reservedAt  DateTime?
  createdAt   DateTime        @default(now())

  delivery Delivery?

  @@index([productId, status])
}

// ---------------------------------------------------------------------------
// Bot settings (editable texts, names, emoji and feature toggles)
// ---------------------------------------------------------------------------

model BotSetting {
  key       String   @id
  value     String // JSON-encoded value (string / boolean / object)
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Deposits & Withdrawals (card-to-card approval workflow)
// ---------------------------------------------------------------------------

model DepositRequest {
  id           String        @id @default(cuid())
  publicId     String        @unique
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount       BigInt // wallet credit in IRT base minor units
  status       DepositStatus @default(PENDING)
  method       DepositMethod @default(CARD)

  // What the user actually pays (IRT / USDT / TON / XTR).
  payCurrency String @default("IRT")
  payAmount   BigInt @default(0) // unique amount in payCurrency minor units
  payAddress  String? // destination snapshot (card no / wallet address / UID)
  payNetwork  String? // e.g. BEP20 / TRC20 / TON
  payTag      String? // unique transfer-note code (card/UID flows)
  rateUsed    BigInt? // IRT<->pay rate snapshot (x1e8)

  expiresAt     DateTime? // now + 15 min (informational countdown)
  paidClaimedAt DateTime? // set when user taps "I've paid"

  // Telegram Stars idempotency
  starsPayload  String?
  starsChargeId String? @unique

  // User-supplied proof of a card-to-card / crypto transfer.
  cardLast4    String?
  reference    String? // tracking / receipt number
  receiptUrl   String?
  note         String?
  reviewedById String?
  reviewedAt   DateTime?
  rejectReason String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status, createdAt])
  @@index([userId, createdAt])
  @@index([method, status])
}

model WithdrawalRequest {
  id           String           @id @default(cuid())
  publicId     String           @unique
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount       BigInt
  status       WithdrawalStatus @default(PENDING)
  iban         String? // destination sheba/card
  cardNumber   String?
  note         String?
  reviewedById String?
  reviewedAt   DateTime?
  rejectReason String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([status, createdAt])
  @@index([userId, createdAt])
}

// ---------------------------------------------------------------------------
// Refunds (return wallet balance to the customer's bank — KYC verified)
// ---------------------------------------------------------------------------

// A request to return funds to the customer's bank account. To prevent fraud
// the destination card must match a card the user actually deposited from, and
// the request carries identity proof (national id + uploaded national card).
model RefundRequest {
  id       String       @id @default(cuid())
  publicId String       @unique
  userId   String
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount   BigInt
  status   RefundStatus @default(PENDING)

  // KYC / identity
  fullName        String // full legal name as printed on the national card
  nationalId      String // 10-digit national id (کد ملی)
  nationalCardUrl String // uploaded image of the national id card (Blob)

  // Destination bank card (must match the card used for an approved deposit)
  cardNumber String // full destination card number entered by the user
  cardLast4  String // last 4 digits, matched against approved deposits
  iban       String? // optional sheba for payout
  reason     String? // why the user wants a refund

  // The approved deposit whose card matched — proof the destination is theirs.
  matchedDepositId String?

  reviewedById String?
  reviewedAt   DateTime?
  rejectReason String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

// ---------------------------------------------------------------------------
// Support tickets (threaded conversation between user and staff)
// ---------------------------------------------------------------------------

model SupportTicket {
  id          String          @id @default(cuid())
  publicId    String          @unique
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject     String
  category    SupportCategory @default(GENERAL)
  status      SupportStatus   @default(OPEN)
  // Timestamp of the most recent message, for inbox-style ordering.
  lastReplyAt DateTime        @default(now())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  messages TicketMessage[]

  @@index([userId, lastReplyAt])
  @@index([status, lastReplyAt])
}

model TicketMessage {
  id            String        @id @default(cuid())
  ticketId      String
  ticket        SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  // Null author = system message. fromStaff distinguishes user vs support.
  authorId      String?
  fromStaff     Boolean       @default(false)
  body          String
  attachmentUrl String?
  createdAt     DateTime      @default(now())

  @@index([ticketId, createdAt])
}

// ---------------------------------------------------------------------------
// Audit log (append-only)
// ---------------------------------------------------------------------------

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id])
  action    String
  entity    String
  entityId  String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Giveaways / Campaigns
// ---------------------------------------------------------------------------

enum GiveawayStatus {
  DRAFT // created, not published
  SCHEDULED // published, before startAt
  ACTIVE // accepting entries
  PAUSED // entries temporarily closed
  LOCKED // entries closed, awaiting admin draw approval
  DRAWING // draw in progress
  FINISHED // winners drawn
  CANCELLED
}

enum GiveawayPrizeKind {
  WALLET // auto-credit a Toman amount to the winner's wallet
  COUPON // auto-generate a unique discount coupon per winner
  INVENTORY // claim a single-use inventory item from a linked product
  CUSTOM // free-form prize delivered manually by an admin
}

enum GiveawayVisibility {
  PUBLIC // listed on the public giveaways page
  UNLISTED // reachable by direct link / deep link only
}

enum GiveawayEntrySource {
  WEB
  BOT
}

model Giveaway {
  id            String             @id @default(cuid())
  slug          String             @unique // unguessable public reference
  title         String
  subtitle      String?
  description   String? // rich text / markdown-ish
  // Native multilingual copy generated by the AI Copilot (fa/en/ru/hi).
  i18n          Json?
  coverImage    String?
  prizeImage    String?
  // Display label for the prize (e.g. "اشتراک یک‌ماهه VPN", "۵۰۰ هزار تومان اعتبار").
  prizeLabel    String
  prizeKind     GiveawayPrizeKind  @default(CUSTOM)
  // WALLET: amount in minor units (Toman). Other kinds: null.
  prizeAmount   BigInt?
  // INVENTORY: the product whose inventory pool prizes are claimed from.
  prizeProductId String?
  prizeProduct  Product?           @relation(fields: [prizeProductId], references: [id], onDelete: SetNull)
  // COUPON: template used to mint a per-winner coupon (type/value/expiry days).
  couponType    CouponType?
  couponValue   BigInt?
  couponExpiresInDays Int?
  winnersCount  Int                @default(1)
  // Required Telegram channels to be eligible. Array of { id, title, url }.
  requiredChannels Json?
  startAt       DateTime
  endAt         DateTime
  drawAt        DateTime
  // IANA timezone label for admin display (storage is always UTC).
  timezone      String             @default("Asia/Tehran")
  status        GiveawayStatus     @default(DRAFT)
  visibility    GiveawayVisibility @default(PUBLIC)
  autoDraw      Boolean            @default(false) // draw automatically at drawAt without admin approval
  internalNotes String?
  // True once admins have been alerted ~5 min before drawAt (avoids duplicate alerts).
  preDrawNotified Boolean          @default(false)
  // Cryptographic seed recorded at draw time so the selection is auditable/reproducible.
  drawSeed      String?
  drawnAt       DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  entries GiveawayEntry[]
  winners GiveawayWinner[]

  @@index([status, drawAt])
  @@index([visibility, status])
}

model GiveawayEntry {
  id         String              @id @default(cuid())
  giveawayId String
  giveaway   Giveaway            @relation(fields: [giveawayId], references: [id], onDelete: Cascade)
  userId     String
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Snapshot of the Telegram id at entry time (anti-fraud / audit).
  telegramId String?
  source     GiveawayEntrySource @default(WEB)
  // Eligibility recomputed at entry and re-validated before the draw. A user who
  // leaves a required channel before the draw is flipped ineligible.
  eligible   Boolean             @default(true)
  createdAt  DateTime            @default(now())

  winner GiveawayWinner?

  // One entry per user per giveaway (hard anti-duplicate guard).
  @@unique([giveawayId, userId])
  @@index([giveawayId, eligible])
}

model GiveawayWinner {
  id         String         @id @default(cuid())
  giveawayId String
  giveaway   Giveaway       @relation(fields: [giveawayId], references: [id], onDelete: Cascade)
  entryId    String         @unique
  entry      GiveawayEntry  @relation(fields: [entryId], references: [id], onDelete: Cascade)
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  position   Int // 1-based winner index
  // Prize delivery lifecycle.
  delivered  Boolean        @default(false)
  deliveredAt DateTime?
  // Delivered payload (coupon code, credentials, claim note) — never shown publicly.
  claimData  Json?
  deliveryError String?
  createdAt  DateTime       @default(now())

  @@unique([giveawayId, userId])
  @@index([giveawayId, position])
}

// ===========================================================================
// Gamification: loyalty points, VIP tiers, achievements/badges & missions
// ===========================================================================

enum VipTier {
  STANDARD
  BRONZE
  SILVER
  GOLD
  DIAMOND
  // PLATINUM is deprecated (migrated to DIAMOND). Kept because Postgres cannot
  // drop an enum value; no new rows should ever use it.
  PLATINUM
  // VIP is an exclusive, admin-granted membership (see vipManual). The auto
  // ladder never assigns VIP; it is layered on top via vipManual.
  VIP
}

enum PointReason {
  PURCHASE
  REFERRAL
  GIVEAWAY_ENTRY
  DAILY_LOGIN
  PROFILE_COMPLETE
  MISSION_REWARD
  ACHIEVEMENT
  ADMIN_ADJUSTMENT
  REDEEM
}

enum MissionKind {
  DAILY
  WEEKLY
}

// Concrete, trackable user activities a mission can be bound to.
enum MissionType {
  DAILY_LOGIN
  VIEW_FLASH_SALE
  INVITE_FRIEND
  PLACE_BID
  COMPLETE_PROFILE
  ENTER_GIVEAWAY
  MAKE_PURCHASE
}

// Immutable, append-only points ledger. balanceAfter snapshots loyaltyPoints
// immediately after the entry, mirroring the wallet ledger design.
model PointLedger {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  delta        Int // signed change in spendable points
  balanceAfter Int
  reason       PointReason
  refType      String?
  refId        String?
  note         String?
  createdAt    DateTime    @default(now())

  @@index([userId, createdAt])
  @@index([reason, createdAt])
}

// Catalog of achievement badges. Code is a stable identifier used in code.
model Badge {
  code         String   @id // e.g. "FIRST_PURCHASE"
  name         String
  description  String
  icon         String // lucide icon name rendered in the UI
  points       Int      @default(0) // bonus points granted when awarded
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userBadges UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeCode String
  badge     Badge    @relation(fields: [badgeCode], references: [code], onDelete: Cascade)
  awardedAt DateTime @default(now())

  @@unique([userId, badgeCode])
  @@index([userId])
}

// Admin-configurable daily/weekly missions.
model Mission {
  id           String      @id @default(cuid())
  key          String      @unique // stable identifier, e.g. "daily_login"
  kind         MissionKind
  type         MissionType
  title        String
  description  String
  target       Int         @default(1) // progress required to complete
  rewardPoints Int         @default(0)
  href         String? // optional deep link to perform the mission
  icon         String      @default("Target")
  isActive     Boolean     @default(true)
  displayOrder Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  userMissions UserMission[]
}

// Per-user progress on a mission for a given period (day or ISO week).
model UserMission {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  missionId   String
  mission     Mission   @relation(fields: [missionId], references: [id], onDelete: Cascade)
  // periodKey isolates progress per period, e.g. "2026-06-26" or "2026-W26".
  periodKey   String
  progress    Int       @default(0)
  completedAt DateTime?
  claimedAt   DateTime?
  updatedAt   DateTime  @updatedAt

  @@unique([userId, missionId, periodKey])
  @@index([userId, periodKey])
}

// ---------------------------------------------------------------------------
// Operations & Monitoring (Operations Center)
// ---------------------------------------------------------------------------

enum ServiceStatus {
  UP
  DEGRADED
  DOWN
  UNKNOWN
}

enum ErrorSource {
  WEB
  MINIAPP
  BOT
  API
  SERVER_ACTION
  WORKER
  CRON
  QUEUE
  WEBHOOK
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AlertComparator {
  GT
  LT
}

enum AlertStatus {
  FIRING
  RESOLVED
}

// Time-series store for every collected metric (infra / app / business).
// Kept compact; old rows are pruned by the monitor cron.
model MetricSample {
  id        String   @id @default(cuid())
  name      String // metric key, e.g. "system.cpu.load1" or "app.rps"
  value     Float
  labels    Json? // optional dimensions, e.g. { service: "api", route: "/x" }
  capturedAt DateTime @default(now())

  @@index([name, capturedAt])
  @@index([capturedAt])
}

// Latest health snapshot per service (upserted on each probe run).
model ServiceHealth {
  id        String        @id @default(cuid())
  service   String        @unique // registry key, e.g. "postgres", "bot"
  status    ServiceStatus @default(UNKNOWN)
  latencyMs Float?
  message   String?
  meta      Json?
  checkedAt DateTime      @default(now())

  @@index([status])
}

// Sentry-style grouped error events (deduplicated by fingerprint).
model ErrorEvent {
  id          String      @id @default(cuid())
  level       String      @default("error") // error | warning | info | fatal
  source      ErrorSource @default(API)
  name        String // error class / type
  message     String
  stack       String?
  fingerprint String      @unique // grouping key (source + name + norm message)
  context     Json?
  userId      String?
  release     String?
  count       Int         @default(1)
  resolved    Boolean     @default(false)
  resolvedAt  DateTime?
  firstSeenAt DateTime    @default(now())
  lastSeenAt  DateTime    @default(now())

  @@index([resolved, lastSeenAt])
  @@index([source, lastSeenAt])
}

// Threshold/anomaly rule that drives alerting.
model AlertRule {
  id             String          @id @default(cuid())
  name           String
  metric         String // metric key this rule watches
  comparator     AlertComparator @default(GT)
  threshold      Float
  forSeconds     Int             @default(0) // sustained duration before firing
  severity       AlertSeverity   @default(WARNING)
  channels       Json            @default("[\"dashboard\"]") // ["telegram","email","dashboard"]
  enabled        Boolean         @default(true)
  cooldownSeconds Int            @default(900)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  events AlertEvent[]

  @@index([enabled])
}

// A fired alert occurrence (open → resolved lifecycle).
model AlertEvent {
  id         String        @id @default(cuid())
  ruleId     String?
  rule       AlertRule?    @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  title      String
  severity   AlertSeverity @default(WARNING)
  status     AlertStatus   @default(FIRING)
  metric     String?
  value      Float?
  message    String
  meta       Json?
  acked      Boolean       @default(false)
  startedAt  DateTime      @default(now())
  resolvedAt DateTime?

  @@index([status, startedAt])
  @@index([severity, startedAt])
}

// ---------------------------------------------------------------------------
// Email infrastructure (enterprise-grade queue + delivery tracking)
// ---------------------------------------------------------------------------

enum EmailStatus {
  QUEUED // accepted, waiting for a worker
  PROCESSING // claimed by a worker, send in flight
  SENT // handed to the provider successfully
  DELIVERED // provider confirmed delivery (webhook)
  FAILED // permanently failed (gave up after retries / 4xx)
  BOUNCED // recipient bounced (webhook)
  COMPLAINED // marked as spam (webhook)
  CANCELED // canceled before sending (e.g. invalid address)
}

// Catalog of transactional templates. Adding a value here + a renderer in
// lib/email/templates.ts is all that's needed for a new email type.
enum EmailTemplateKey {
  WELCOME
  EMAIL_VERIFICATION
  PASSWORD_RESET
  PURCHASE_CONFIRMATION
  WALLET_DEPOSIT_APPROVED
  WALLET_DEPOSIT_REJECTED
  REFUND_COMPLETED
  GIVEAWAY_WINNER
  GIVEAWAY_REGISTRATION
  AUCTION_WINNER
  AUCTION_OUTBID
  VIP_ACTIVATED
  REFERRAL_REWARD
  SUPPORT_REPLY
  SECURITY_ALERT
  GENERIC
}

// Verified sender identities. The actual From address for each is resolved
// from settings/env at send time (lib/email/senders.ts).
enum EmailSenderId {
  NOREPLY
  SUPPORT
  BILLING
  SECURITY
}

// A single queued/processed email. This is BOTH the durable work item and the
// delivery record, so queued mail survives restarts and is captured by the DB
// backup automatically. Idempotency is enforced by `idempotencyKey`.
model EmailJob {
  id               String           @id @default(cuid())
  idempotencyKey   String           @unique
  template         EmailTemplateKey
  sender           EmailSenderId    @default(NOREPLY)
  to               String
  locale           String           @default("fa")
  subject          String
  payload          Json? // template variables (rendered at send time)
  status           EmailStatus      @default(QUEUED)
  priority         Int              @default(5) // lower runs sooner
  attempts         Int              @default(0)
  maxAttempts      Int              @default(5)
  nextAttemptAt    DateTime         @default(now())
  lastError        String?
  providerId       String? // Resend message id
  providerResponse Json?
  userId           String? // soft reference (no FK) for analytics/audit
  openCount        Int              @default(0)
  clickCount       Int              @default(0)
  queuedAt         DateTime         @default(now())
  processingAt     DateTime?
  sentAt           DateTime?
  deliveredAt      DateTime?
  failedAt         DateTime?
  openedAt         DateTime?
  clickedAt        DateTime?
  updatedAt        DateTime         @updatedAt

  events EmailEvent[]

  @@index([status, nextAttemptAt])
  @@index([template, queuedAt])
  @@index([to])
  @@index([providerId])
  @@index([queuedAt])
}

// Raw provider lifecycle events (delivered, bounced, opened, clicked, …),
// kept for the full audit trail and analytics.
model EmailEvent {
  id         String    @id @default(cuid())
  jobId      String?
  job        EmailJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)
  providerId String?
  type       String // provider event type, e.g. "email.delivered"
  payload    Json?
  occurredAt DateTime  @default(now())

  @@index([jobId])
  @@index([type, occurredAt])
  @@index([providerId])
}

// ---------------------------------------------------------------------------
// AI Platform (shared core for every AI capability across SubIO)
//
// Design goals: provider-agnostic (no code path is bound to OpenAI), secrets
// encrypted at rest, full usage/cost observability, prompt versioning and a
// memory store — all consumed through one gateway (`lib/ai`). Non-secret
// settings (provider, model, temperature, limits, toggles) live in the generic
// `Setting` table under `ai.*` keys; only secret API keys live here, encrypted.
// ---------------------------------------------------------------------------

// One encrypted API key per provider (e.g. "openai", "anthropic", "gateway").
// The ciphertext is AES-256-GCM; the raw key is never stored or returned to any
// client. Only a Super Admin may read (masked) or mutate these rows.
model AiCredential {
  id           String    @id @default(cuid())
  // Stable provider slug from the provider registry (lib/ai/providers.ts).
  provider     String    @unique
  // AES-256-GCM payload: iv:authTag:ciphertext (all base64), see lib/ai/crypto.
  ciphertext   String
  // Last 4 chars of the raw key, kept for a "•••• 1234" hint in the UI.
  last4        String?
  // Free-form label (e.g. "Production key").
  label        String?
  // Result of the most recent Test Connection: "connected" | "error" | "invalid".
  status       String    @default("unknown")
  statusDetail String?
  lastTestedAt DateTime?
  createdById  String?
  updatedById  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// One row per AI generation. The authoritative record for usage, token and cost
// analytics, latency observability and audit. Written by the gateway wrapper for
// every call (success or failure) so nothing bypasses tracking.
model AiUsageEvent {
  id           String   @id @default(cuid())
  // Logical capability that made the call, e.g. "content.seo", "support.reply",
  // "copilot", "translate". Free-form so new features need no migration.
  feature      String
  provider     String
  model        String
  operation    String   @default("generateText") // generateText | generateObject | stream | embed | image
  // Optional actor + correlation for per-user analytics and rate limiting.
  userId       String?
  refType      String?
  refId        String?
  // Token accounting (nullable — some providers omit parts).
  inputTokens  Int?
  outputTokens Int?
  totalTokens  Int?
  // Estimated cost in micro-USD (millionths of a dollar) to avoid float drift.
  costMicroUsd BigInt   @default(0)
  latencyMs    Int?
  ok           Boolean  @default(true)
  errorCode    String?
  errorMessage String?
  // Arbitrary structured context (prompt id/version, temperature, etc.).
  meta         Json?
  createdAt    DateTime @default(now())

  @@index([feature, createdAt])
  @@index([provider, model, createdAt])
  @@index([userId, createdAt])
  @@index([createdAt])
}

// A named, versioned prompt. The current pointer is `activeVersion`; history is
// kept in AiPromptVersion so prompts can be rolled back and A/B compared.
model AiPromptTemplate {
  id            String             @id @default(cuid())
  // Stable key referenced from code, e.g. "support.reply", "content.seo".
  key           String             @unique
  name          String
  description   String?
  feature       String? // grouping for the prompt library UI
  activeVersion Int                @default(1)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  versions AiPromptVersion[]

  @@index([feature])
}

model AiPromptVersion {
  id           String           @id @default(cuid())
  templateId   String
  template     AiPromptTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  version      Int
  // Handlebars-style {{variable}} placeholders rendered at call time.
  systemPrompt String?
  userPrompt   String
  // Optional per-prompt model/params override (JSON: { model, temperature, ... }).
  config       Json?
  notes        String?
  createdById  String?
  createdAt    DateTime         @default(now())

  @@unique([templateId, version])
}

// Durable AI memory. `scope` + `scopeId` namespace entries (e.g.
// scope="user", scopeId=<userId>; or scope="global"). `key` is unique per scope.
model AiMemory {
  id        String   @id @default(cuid())
  scope     String   @default("global")
  scopeId   String   @default("global")
  key       String
  value     Json
  // Optional soft expiry for transient memories.
  expiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([scope, scopeId, key])
  @@index([scope, scopeId])
  @@index([expiresAt])
}

// ---------------------------------------------------------------------------
// AI Knowledge Base (RAG). Documents are chunked and embedded into pgvector.
// The `embedding` column uses the pgvector `vector` type (Unsupported by
// Prisma); all similarity search happens via raw SQL using the `<=>` operator.
// Dimension 1536 matches OpenAI text-embedding-3-small (configurable model must
// match this dimension, or re-provision the column).
// ---------------------------------------------------------------------------

enum AiKnowledgeStatus {
  READY
  INDEXING
  ERROR
}

model AiKnowledgeDoc {
  id          String            @id @default(cuid())
  title       String
  // Origin of the content: manual entry, imported URL, or an FAQ pair.
  source      String            @default("manual")
  sourceUrl   String?
  category    String?
  locale      String            @default("fa")
  // Whether this doc may be surfaced to end users (support) vs admin-only.
  isPublic    Boolean           @default(true)
  content     String
  status      AiKnowledgeStatus @default(READY)
  chunkCount  Int               @default(0)
  error       String?
  createdById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  chunks AiKnowledgeChunk[]

  @@index([status])
  @@index([isPublic])
}

model AiKnowledgeChunk {
  id        String                       @id @default(cuid())
  docId     String
  doc       AiKnowledgeDoc               @relation(fields: [docId], references: [id], onDelete: Cascade)
  idx       Int
  content   String
  tokens    Int                          @default(0)
  embedding Unsupported("vector(1536)")?
  createdAt DateTime                     @default(now())

  @@index([docId])
}

// ---------------------------------------------------------------------------
// AI Automation. Scheduled AI-driven tasks executed by the cron tick. Each
// automation has a stable `key` (matches a handler in the registry) that admins
// can enable/disable and reschedule. Automations are advisory: they produce
// digests, alerts, and admin notifications — never silent mutations of
// customer-facing data. Every execution is recorded in AiAutomationRun.
// ---------------------------------------------------------------------------

model AiAutomation {
  id          String              @id @default(cuid())
  // Stable identifier that maps to a handler in the automation registry.
  key         String              @unique
  enabled     Boolean             @default(false)
  // Cron-like cadence in minutes between runs (the tick enforces the interval).
  intervalMin Int                 @default(1440)
  // Free-form per-automation config (thresholds, recipients, locale, ...).
  config      Json?
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  lastStatus  String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  runs AiAutomationRun[]

  @@index([enabled])
}

model AiAutomationRun {
  id           String       @id @default(cuid())
  automationId String
  automation   AiAutomation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  status       String // "ok" | "error" | "skipped"
  summary      String?
  detail       Json?
  error        String?
  durationMs   Int          @default(0)
  createdAt    DateTime     @default(now())

  @@index([automationId, createdAt])
}

// ---------------------------------------------------------------------------
// Rich Content Platform
// Shared editor infrastructure used by every long-form content surface
// (products, auctions, giveaways, articles, FAQ, rules, emails, channel posts).
// Content itself lives on each owning model as standard semantic HTML; these
// tables back the cross-cutting features (media library, snippets, revisions).
// ---------------------------------------------------------------------------

enum MediaKind {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  ARCHIVE
  OTHER
}

/// Optional folders for organizing the shared Media Library.
model MediaFolder {
  id        String        @id @default(cuid())
  name      String
  parentId  String?
  parent    MediaFolder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  MediaFolder[] @relation("FolderTree")
  assets    MediaAsset[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([parentId])
}

/// Every file uploaded through the Media Manager. `url` is the Blob URL (or the
/// authenticated proxy path for private files). Deleting a folder detaches its
/// assets rather than removing the files.
model MediaAsset {
  id           String       @id @default(cuid())
  url          String
  pathname     String?      // Blob pathname, for deletion
  kind         MediaKind    @default(OTHER)
  mimeType     String
  filename     String
  size         Int          @default(0)
  width        Int?
  height       Int?
  blurDataUrl  String?      // tiny base64 placeholder for images
  alt          String?
  caption      String?
  tags         String[]     @default([])
  folderId     String?
  folder       MediaFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  uploadedById String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([kind])
  @@index([folderId])
  @@index([createdAt])
}

/// Reusable content blocks/snippets. Body is canonical semantic HTML; inserting
/// a snippet expands it into normal editable nodes (copy-in, not live-linked).
model ContentSnippet {
  id          String   @id @default(cuid())
  name        String
  category    String?
  html        String   // semantic HTML body
  scope       String   @default("global") // reserved for future per-section scoping
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([name])
}

/// Version history for any rich field. `entityType`+`entityId`+`field`
/// identifies the owning column; `status` distinguishes drafts, the published
/// snapshot, and prior revisions so any version can be restored.
model ContentRevision {
  id          String   @id @default(cuid())
  entityType  String // e.g. "product", "article", "faq"
  entityId    String
  field       String   @default("description")
  html        String
  status      String   @default("revision") // "draft" | "published" | "revision"
  note        String?
  createdById String?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId, field, createdAt])
}

/// Forward-compatibility only (NOT wired this phase): inline comment threads
/// anchored to a `data-comment-id` mark in the content. Present so future
/// collaboration/commenting needs no storage-format change or data migration.
model ContentComment {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  field      String   @default("description")
  anchorId   String // matches data-comment-id in the HTML
  body       String
  authorId   String?
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([entityType, entityId, field])
  @@index([anchorId])
}
